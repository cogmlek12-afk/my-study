\uc0\u48320 \u49688 \u47484  private\u51004 \u47196  \u49440 \u50616 \u54644 \u49436  \u50808 \u48512 \u50640 \u49436  \u51649 \u51217  \u51217 \u44540 \u54616 \u51648  \u47803 \u54616 \u44172  \u54616 \u44256 , getter\u50752  setter\u47484  \u51060 \u50857 \u54644 \u49436  \u44050 \u51012  \u44032 \u51256 \u50724 \u44144 \u45208  \u48320 \u44221 \u54624  \u49688  \u51080 \u49845 \u45768 \u45796 .\
\uc0\u50696 \u47484  \u46308 \u50612  \u54872 \u51088  \u51221 \u48372 \u50640 \u49436  \u51060 \u47492 \u51060 \u45208  \u45208 \u51060  \u44057 \u51008  \u45936 \u51060 \u53552 \u47484  \u51649 \u51217  \u48320 \u44221 \u54616 \u51648  \u47803 \u54616 \u46020 \u47197  \u47561 \u44256 , \u54596 \u50836 \u54620  \u47700 \u49548 \u46300 \u47484  \u53685 \u54644  \u51217 \u44540 \u54616 \u45716  \u48169 \u49885 \u51077 \u45768 \u45796 .\
